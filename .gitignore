# Build outputs — exclude everything in bin/ and obj/ EXCEPT the vsixmanifest caches
bin/
obj/
# Allow the manifest caches so MSBuild reads the correct one
!Base44AIPilot/obj/
!Base44AIPilot/obj/Debug/
!Base44AIPilot/obj/Debug/extension.vsixmanifest
!Base44AIPilot/obj/Release/
!Base44AIPilot/obj/Release/extension.vsixmanifest

# VS IDE
.vs/
*.user
*.suo

# NuGet
packages/
*.nupkg

# MSBuild cache files (keep manifests above)
*.cache
*.tlog
*.Up2Date
*.cto
*.g.cs
*.g.i.cs
*.baml
*.resources
*.FileListAbsolute.txt

# Misc
*.tmp
*.log
Thumbs.db
desktop.ini
