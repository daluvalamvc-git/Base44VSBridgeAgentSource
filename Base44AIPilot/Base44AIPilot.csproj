<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <MinimumVisualStudioVersion>17.0</MinimumVisualStudioVersion>
    <VSToolsPath Condition="'$(VSToolsPath)' == ''">$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)</VSToolsPath>
    <UseCodebase>true</UseCodebase>
    <NuGetPackageImportStamp>
    </NuGetPackageImportStamp>
  </PropertyGroup>
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <ProjectTypeGuids>{82b43b9b-a64c-4715-b499-d71e9ca2bd60};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>Base44AIPilot</RootNamespace>
    <AssemblyName>Base44AIPilot</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <GeneratePkgDefFile>false</GeneratePkgDefFile>
    <IncludeAssemblyInVSIXContainer>true</IncludeAssemblyInVSIXContainer>
    <IncludeDebugSymbolsInVSIXContainer>true</IncludeDebugSymbolsInVSIXContainer>
    <IncludeDebugSymbolsInLocalVSIXDeployment>true</IncludeDebugSymbolsInLocalVSIXDeployment>
    <CopyBuildOutputToOutputDirectory>true</CopyBuildOutputToOutputDirectory>
    <CopyOutputSymbolsToOutputDirectory>false</CopyOutputSymbolsToOutputDirectory>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <CreateVsixContainer>true</CreateVsixContainer>
    <DeployExtension>false</DeployExtension>
    <PlatformTarget>AnyCPU</PlatformTarget>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <CreateVsixContainer>true</CreateVsixContainer>
    <DeployExtension>false</DeployExtension>
  </PropertyGroup>
  <!--
    Assembly paths:
    $(VSSDK_INSTALL_DIR)..\..\Common7\IDE\PublicAssemblies\   — Shell, Interop, etc.
    $(VSSDK_INSTALL_DIR)..\..\Common7\IDE\PrivateAssemblies\  — EnvDTE, EnvDTE80

    Microsoft.VisualStudio.Threading is NOT referenced here.
    All JoinableTaskFactory usages were rewritten to go through instance members
    (this.JoinableTaskFactory / package.JoinableTaskFactory) or WPF Dispatcher,
    so the compiler resolves the type through AsyncPackage's own assembly
    without needing an explicit assembly reference.
  -->
  <PropertyGroup>
    <VsPublicAssemblies>$(VSSDK_INSTALL_DIR)..\..\Common7\IDE\PublicAssemblies\</VsPublicAssemblies>
    <VsPrivateAssemblies>$(VSSDK_INSTALL_DIR)..\..\Common7\IDE\PrivateAssemblies\</VsPrivateAssemblies>
  </PropertyGroup>
  <ItemGroup>
    <!-- GAC / Framework -->
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Design" />
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Runtime.Serialization" />
    <Reference Include="System.Xaml" />
    <Reference Include="System.Xml" />
    <Reference Include="WindowsBase" />
    <!-- VS Shell — PublicAssemblies -->
    <Reference Include="Microsoft.VisualStudio.Shell.15.0">
      <HintPath>$(VsPublicAssemblies)Microsoft.VisualStudio.Shell.15.0.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Microsoft.VisualStudio.Shell.Framework">
      <HintPath>$(VsPublicAssemblies)Microsoft.VisualStudio.Shell.Framework.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Microsoft.VisualStudio.Shell.Interop">
      <HintPath>$(VsPublicAssemblies)Microsoft.VisualStudio.Shell.Interop.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Microsoft.VisualStudio.Shell.Interop.8.0">
      <HintPath>$(VsPublicAssemblies)Microsoft.VisualStudio.Shell.Interop.8.0.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Microsoft.VisualStudio.Shell.Interop.9.0">
      <HintPath>$(VsPublicAssemblies)Microsoft.VisualStudio.Shell.Interop.9.0.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Microsoft.VisualStudio.Shell.Interop.10.0">
      <HintPath>$(VsPublicAssemblies)Microsoft.VisualStudio.Shell.Interop.10.0.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Microsoft.VisualStudio.OLE.Interop">
      <HintPath>$(VsPublicAssemblies)Microsoft.VisualStudio.OLE.Interop.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <!-- Required in VS 2022: IVsWindowFrame, IOleCommandTarget, IVsPackage etc.
         were type-forwarded into this assembly. -->
    <Reference Include="Microsoft.VisualStudio.Interop">
      <HintPath>$(VsPublicAssemblies)Microsoft.VisualStudio.Interop.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <!-- Required by CreatePkgDef reflection on PackageRegistrationAttribute -->
    <Reference Include="Microsoft.VisualStudio.Utilities">
      <HintPath>$(VsPublicAssemblies)Microsoft.VisualStudio.Utilities.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <!-- EnvDTE / EnvDTE80 — PrivateAssemblies -->
    <Reference Include="EnvDTE">
      <HintPath>$(VsPrivateAssemblies)EnvDTE.dll</HintPath>
      <Private>False</Private>
      <EmbedInteropTypes>false</EmbedInteropTypes>
    </Reference>
    <Reference Include="EnvDTE80">
      <HintPath>$(VsPrivateAssemblies)EnvDTE80.dll</HintPath>
      <Private>False</Private>
      <EmbedInteropTypes>false</EmbedInteropTypes>
    </Reference>
    <!-- Newtonsoft.Json — only real NuGet DLL in VSIX output -->
    <Reference Include="Newtonsoft.Json">
      <HintPath>$(SolutionDir)packages\Newtonsoft.Json.13.0.3\lib\net45\Newtonsoft.Json.dll</HintPath>
      <Private>True</Private>
    </Reference>
  </ItemGroup>
  <!-- C# source files -->
  <ItemGroup>
    <Compile Include="Base44AIPilotPackage.cs" />
    <Compile Include="Commands\Base44AICommands.cs" />
    <Compile Include="Models\SolutionFile.cs" />
    <Compile Include="Options\Base44OptionsPage.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Include="Services\ApiClient.cs" />
    <Compile Include="Services\DiffParser.cs" />
    <Compile Include="Services\SolutionReader.cs" />
    <Compile Include="ToolWindows\Base44ChatWindow.cs" />
    <Compile Include="ToolWindows\Base44ChatWindowControl.xaml.cs">
      <DependentUpon>Base44ChatWindowControl.xaml</DependentUpon>
    </Compile>
    <Compile Include="UI\DiffPreviewDialog.xaml.cs">
      <DependentUpon>DiffPreviewDialog.xaml</DependentUpon>
    </Compile>
  </ItemGroup>
  <!-- WPF XAML -->
  <ItemGroup>
    <Page Include="ToolWindows\Base44ChatWindowControl.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
    <Page Include="UI\DiffPreviewDialog.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
  </ItemGroup>
  <!-- Resources -->
  <ItemGroup>
    <EmbeddedResource Include="Resources\Base44AIPilot.resx" />
  </ItemGroup>
  <!-- VSIX manifest and icon -->
  <ItemGroup>
    <None Include="packages.config" />
    <Content Include="Base44AIPilot.pkgdef">
      <IncludeInVSIX>true</IncludeInVSIX>
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
    <None Include="source.extension.vsixmanifest">
      <SubType>Designer</SubType>
    </None>
    <Content Include="Resources\icon.png">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
  </ItemGroup>
  <!-- VSCT -->
  <ItemGroup>
    <VSCTCompile Include="Commands\Base44AICommands.vsct">
      <ResourceName>Menus.ctmenu</ResourceName>
    </VSCTCompile>
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <Import Project="$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets" Condition="Exists('$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets')" />
</Project>